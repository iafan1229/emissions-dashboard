generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ImportBatch {
  id          String         @id @default(cuid())
  companyId   String
  productId   String
  productName String
  filename    String
  uploadedAt  DateTime       @default(now())
  rowCount    Int
  activities  ActivityData[]

  @@index([companyId, productId])
  @@index([uploadedAt])
}

model ActivityData {
  id            String      @id @default(cuid())
  date          DateTime    @db.Date
  activityType  String
  description   String
  amount        Decimal     @db.Decimal(12, 4)
  unit          String
  companyId     String
  productId     String
  importBatchId String
  importBatch   ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)

  @@unique([companyId, productId, date, activityType, description, amount], name: "activity_dedup")
  @@index([productId])
  @@index([companyId])
  @@index([date])
}
